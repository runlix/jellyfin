{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate configuration for Jellyfin release branch docker-matrix updates",
  "extends": [
    "config:recommended"
  ],
  "baseBranches": [
    "release"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Debian builder images (BUILDER_TAG + BUILDER_DIGEST)",
      "fileMatch": [
        "^\\.ci/docker-matrix\\.json$"
      ],
      "matchStrings": [
        "\\\"BUILDER_TAG\\\"\\s*:\\s*\\\"(?<currentValue>[^\\\"]+)\\\"[\\s\\S]*?\\\"BUILDER_DIGEST\\\"\\s*:\\s*\\\"(?<currentDigest>sha256:[a-f0-9]{64})\\\""
      ],
      "depNameTemplate": "docker.io/library/debian",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update Distroless runtime base images (BASE_TAG + BASE_DIGEST)",
      "fileMatch": [
        "^\\.ci/docker-matrix\\.json$"
      ],
      "matchStrings": [
        "\\\"BASE_TAG\\\"\\s*:\\s*\\\"(?<currentValue>[^\\\"]+)\\\"[\\s\\S]*?\\\"BASE_DIGEST\\\"\\s*:\\s*\\\"(?<currentDigest>sha256:[a-f0-9]{64})\\\""
      ],
      "depNameTemplate": "ghcr.io/runlix/distroless-runtime",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update Jellyfin version from GitHub releases",
      "fileMatch": [
        "^\\.ci/docker-matrix\\.json$"
      ],
      "matchStrings": [
        "\\\"version\\\"\\s*:\\s*\\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "depNameTemplate": "jellyfin/jellyfin",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update Jellyfin amd64 package URL from release version",
      "fileMatch": [
        "^\\.ci/docker-matrix\\.json$"
      ],
      "matchStrings": [
        "\\\"PACKAGE_URL\\\"\\s*:\\s*\\\"https://repo\\.jellyfin\\.org/files/server/linux/stable/v(?<currentValue>[^/]+)/amd64/jellyfin_[^\\\"]+\\\""
      ],
      "depNameTemplate": "jellyfin/jellyfin",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "\"PACKAGE_URL\": \"https://repo.jellyfin.org/files/server/linux/stable/v{{{newValue}}}/amd64/jellyfin_{{{newValue}}}-amd64.tar.gz\""
    },
    {
      "customType": "regex",
      "description": "Update Jellyfin arm64 package URL from release version",
      "fileMatch": [
        "^\\.ci/docker-matrix\\.json$"
      ],
      "matchStrings": [
        "\\\"PACKAGE_URL\\\"\\s*:\\s*\\\"https://repo\\.jellyfin\\.org/files/server/linux/stable/v(?<currentValue>[^/]+)/arm64/jellyfin_[^\\\"]+\\\""
      ],
      "depNameTemplate": "jellyfin/jellyfin",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "\"PACKAGE_URL\": \"https://repo.jellyfin.org/files/server/linux/stable/v{{{newValue}}}/arm64/jellyfin_{{{newValue}}}-arm64.tar.gz\""
    }
  ],
  "packageRules": [
    {
      "description": "Group docker-matrix updates into daily PRs",
      "matchFileNames": [
        "**/.ci/docker-matrix.json"
      ],
      "groupName": "Docker base images",
      "schedule": [
        "before 3am"
      ]
    },
    {
      "description": "Separate Debian builder updates",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "docker.io/library/debian"
      ],
      "groupName": "Debian builder",
      "commitMessageTopic": "Debian builder image"
    },
    {
      "description": "Separate Distroless runtime updates",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/runlix/distroless-runtime"
      ],
      "groupName": "Distroless runtime",
      "commitMessageTopic": "Distroless runtime base image"
    },
    {
      "description": "Group Jellyfin release version/url updates with automerge",
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "jellyfin/jellyfin"
      ],
      "groupName": "Jellyfin release",
      "commitMessageTopic": "Jellyfin version",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Auto-merge digest-only updates",
      "matchFileNames": [
        "**/.ci/docker-matrix.json"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "🔄 Dependency Updates Dashboard",
  "dependencyDashboardApproval": false,
  "labels": [
    "dependencies",
    "docker"
  ],
  "timezone": "UTC",
  "prConcurrentLimit": 3,
  "prHourlyLimit": 1
}
